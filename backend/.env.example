# ---- Eleanora Nails: local configuration ----
# Copy this file to `.env` and fill in your own values.
# `.env` is git-ignored, so real secrets never leave your machine.

# Signs session cookies and CSRF tokens.
# In production this MUST be a long random value. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# ---- MySQL ----
DB_USER=root
DB_PASSWORD=kali
DB_HOST=localhost
DB_PORT=3306
DB_NAME=eleanora_nails

# Set to 1 only when the site is served over HTTPS. It turns on the Secure
# cookie flag and the HSTS header; on plain http it would lock you out.
COOKIE_SECURE=0

# ---- Optional: the payment-screenshot reader ----
# Where the Tesseract OCR engine lives. If it is not installed, leave this alone:
# the app notices, logs one line, and runs perfectly well without reading
# receipts automatically. Nothing breaks.
#   Windows default: C:\Program Files\Tesseract-OCR\tesseract.exe
#   macOS / Linux:   just "tesseract" once it is on the PATH
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# ---- Rate limiting ----
# Leave this ON in production. Set to 0 only when running the test suite, which
# drives hundreds of requests from one IP and would otherwise throttle itself.
RATELIMIT_ENABLED=1
